<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data>

        <menuitem id="school_management_menu_root"
            name="School Management"
            action="action_school_detail"/>





<!-- form tag start from here-->

         <record id="school_detail_view_form" model="ir.ui.view">
            <field name="name">school.view.form</field>
            <field name="model">school.detail</field>
            <field name="arch" type="xml">
                <form string="School">
                    <sheet>
                        <group string="School Management">
                            <group>
                                <field name="name"/>
                                <field name="principle"/>
                                <field name ="address"/>
                                <field name='contact' widget='phone'/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


<!-- tree tag start from here-->

      <record id="school_detail_view_tree" model="ir.ui.view">
         <field name="name">school.view.tree</field>
         <field name="model">school.detail</field>
         <field name="arch" type="xml">
             <tree>
                 <field name="name" string="Name" required="1"/>
             </tree>
         </field>
      </record>


        <!-- action field -->

      <record model="ir.actions.act_window" id="action_school_detail">
            <field name="name">School Management</field>
           <field name="res_model">school.detail</field>
            <field name="view_mode">tree,form</field>
        </record>






    </data>
</odoo>

