<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data>

        <menuitem id="school_management_menu_root"
            name="School Management"/>


        <menuitem id="student_detail_menu"
          name="Student"
          parent="school_management_menu_root"
          action="action_student_detail"/>





<!-- form tag start from here-->

         <record id="student_detail_view_form" model="ir.ui.view">
            <field name="name">student.view.form</field>
            <field name="model">student.detail</field>
            <field name="arch" type="xml">
                <form string="Student">
                     <sheet>
                        <group string="Student Management">
                            <group>
                                <field name="name"/>


                                <field name="roll_no"/>


                                <field name="fathers_name"/>

                                <field name="student_class"/>
                                <field name="course_id"/>
                            </group>



                            <group>
                                <field name="student_dob"/>

                                <field name="gender"/>

                                <field name="mobile_number" widget="phone"/>


                                <field name="student_stream"/>


                                <field name="e_mail" widget="email"/>

                                <field name ="transportation"/>
                                <field name="teacher" widget="many2one_widget"/>

                              </group>


                            <group>
                                <field name ="fee_detail" widget="one2many"/>
                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>


<!-- tree tag start from here-->

      <record id="student_detail_view_tree" model="ir.ui.view">
         <field name="name">student.view.tree</field>
         <field name="model">student.detail</field>
         <field name="arch" type="xml">
             <tree>
                 <field name="name" string="Name" required="1"/>
             </tree>
         </field>
      </record>




      <!-- search views -->
       <record id="student_detail_view_search" model="ir.ui.view">
        <field name="name">student.view.search</field>
        <field name="model">student.detail</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="e_mail"/>
                <field name="gender"/>
            </search>
          </field>
        </record>



        <!-- action field -->

      <record model="ir.actions.act_window" id="action_student_detail">
            <field name="name">Student Management</field>
           <field name="res_model">student.detail</field>
            <field name="view_mode">tree,form,search</field>
        </record>






    </data>
</odoo>
