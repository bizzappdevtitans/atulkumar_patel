<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record model="res.groups" id="access_student_profile">
             <field name="name">student school profile</field>


     </record>


     <record model="ir.model.access" id="school_detail_access_end_user_permission">
             <field name="name">End user permission</field>
             <field name="model_id" ref="model_school_student_security"/>
             <field name="perm_read">1</field>
             <field name="perm_create">1</field>
             <field name="perm_write">1</field>
             <field name="perm_unlink">1</field>


     </record>




     <record model="ir.model.access" id="access_school_user_permission">
             <field name="name">Base User</field>
             <field name="model_id" ref="model_school_profile"/>
             <field name="domain_force" >[('create_uid', '=', 'user.id')]></field>
             <field name="groups" eval="[(4, ref(access_school_user_permission))]"/>



     </record>




</odoo>
