<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data>

        <menuitem id="library_management_menu_root"
            name="Library Management"/>

         <menuitem id="library_report_menu"
          name="Library Report"
          groups="group_library_management_report"
          parent="library_management_menu_root"
          action="action_library_report"/>






<!-- form tag start from here-->

         <record id="library_report_view_form" model="ir.ui.view">
            <field name="name">library.report.view.form</field>
            <field name="model">library.report</field>
            <field name="arch" type="xml">
                <form string="Library Report">
                    <sheet>
                        <group string="Library Report Management">
                            <group>
                                <field name="name" string="Name"/>
                                <field name="description" string="Description"/>
                                <field name="report_type" string="Report Type"/>
                                <field name="data" string="Data" readonly="1"/>

                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>





<!-- tree tag start from here-->

      <record id="library_report_view_tree" model="ir.ui.view">
         <field name="name">library.report.view.tree</field>
         <field name="model">library.report</field>
         <field name="arch" type="xml">
             <tree>
                <field name="name" string="Name"/>
                <field name="description" string="Description"/>

                <field name="report_type" string="Report Type"/>

                 <field name="data" string="Data" readonly="1"/>
             </tree>
         </field>
      </record>


        <!-- action field -->

      <record model="ir.actions.act_window" id="action_library_report">
            <field name="name">Library Report Management</field>
           <field name="res_model">library.report</field>
            <field name="view_mode">tree,form</field>
        </record>






    </data>
</odoo>





