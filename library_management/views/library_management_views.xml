<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data>

        <menuitem id="library_management_menu_root"
            name="Library Management"
            action="action_library_management"/>





<!-- form tag start from here-->

         <record id="library_management_view_form" model="ir.ui.view">
            <field name="name">library.view.form</field>
            <field name="model">library.management</field>
            <field name="arch" type="xml">
                <form string="Library">
                    <sheet>
                        <group string="Library Management">
                            <group>
                                <field name="name"/>

                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>





<!-- tree tag start from here-->

      <record id="library_management_view_tree" model="ir.ui.view">
         <field name="name">library.view.tree</field>
         <field name="model">library.management</field>
         <field name="arch" type="xml">
             <tree>
                 <field name="name" string="Name" required="1"/>
             </tree>
         </field>
      </record>


        <!-- action field -->

      <record model="ir.actions.act_window" id="action_library_management">
            <field name="name">Library Management</field>
           <field name="res_model">library.management</field>
            <field name="view_mode">tree,form</field>
        </record>






    </data>
</odoo>



