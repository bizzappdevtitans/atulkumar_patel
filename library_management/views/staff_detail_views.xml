<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data>

        <menuitem id="library_management_menu_root"
            name="Library Management"/>

         <menuitem id="staff_detail_menu"
          name="Staff"

          parent="library_management_menu_root"
          action="action_staff_detail"/>






<!-- form tag start from here-->

         <record id="staff_detail_view_form" model="ir.ui.view">
            <field name="name">staff.view.form</field>
            <field name="model">staff.detail</field>
            <field name="arch" type="xml">
                <form string="Staff">
                    <sheet>
                        <group string="Staff Management">
                            <group>
                                <field name="name"/>

                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>





<!-- tree tag start from here-->

      <record id="staff_detail_view_tree" model="ir.ui.view">
         <field name="name">staff.view.tree</field>
         <field name="model">staff.detail</field>
         <field name="arch" type="xml">
             <tree>
                 <field name="name" string="Name" required="1"/>
             </tree>
         </field>
      </record>


        <!-- action field -->

      <record model="ir.actions.act_window" id="action_staff_detail">
            <field name="name">Staff Management</field>
           <field name="res_model">staff.detail</field>
            <field name="view_mode">tree,form</field>
        </record>






    </data>
</odoo>





